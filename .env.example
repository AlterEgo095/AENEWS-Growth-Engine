# API Gateway
API_PORT=3000
API_HOST=0.0.0.0
NODE_ENV=development

# JWT Authentication
JWT_SECRET=change-me-in-production-use-strong-secret-key
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# Redis (Event Bus & Cache)
REDIS_URL=redis://redis:6379
REDIS_STREAM_NAME=user.events
REDIS_AI_STREAM=ai.decisions
REDIS_MAUTIC_STREAM=mautic.sync
REDIS_PASSWORD=

# Mautic Configuration
MAUTIC_BASE_URL=http://mautic:80
MAUTIC_USERNAME=admin
MAUTIC_PASSWORD=Mautic2024!
MAUTIC_CLIENT_ID=
MAUTIC_CLIENT_SECRET=
MAUTIC_API_TIMEOUT=10000
MAUTIC_MAX_RETRIES=3

# MongoDB (Data Lake)
MONGODB_URI=mongodb://mongodb:27017/aenews
MONGODB_USER=admin
MONGODB_PASSWORD=MongoPass2024!

# MySQL (Mautic DB)
MYSQL_ROOT_PASSWORD=RootPass2024!
MYSQL_DATABASE=mautic
MYSQL_USER=mautic
MYSQL_PASSWORD=MauticDB2024!
MYSQL_HOST=mysql
MYSQL_PORT=3306

# AI Decision Engine
AI_ENGINE_URL=http://ai-engine:8000
OPENAI_API_KEY=sk-your-openai-key-here
AI_MODEL=gpt-4-turbo-preview

# Email Provider (Choose one)
EMAIL_PROVIDER=mailgun
# Mailgun
MAILGUN_DOMAIN=mg.example.com
MAILGUN_API_KEY=key-your-mailgun-api-key
# SendGrid
SENDGRID_API_KEY=SG.your-sendgrid-api-key

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_PASSWORD=GrafanaAdmin2024!

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Circuit Breaker
CIRCUIT_BREAKER_TIMEOUT=3000
CIRCUIT_BREAKER_ERROR_THRESHOLD=50
CIRCUIT_BREAKER_RESET_TIMEOUT=30000

# Security
CORS_ORIGINS=http://localhost:3001,https://app.example.com
HELMET_ENABLED=true

# Feature Flags
ENABLE_AI_ENGINE=true
ENABLE_EVENT_ARCHIVE=true
ENABLE_CIRCUIT_BREAKER=true
